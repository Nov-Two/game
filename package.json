{
	"name": "fe-entry-task",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "vite preview",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"build-only": "vite build && run-p tpl",
		"build:goku": "vite build --mode goku && run-p tpl:goku",
		"type-check": "vue-tsc --build",
		"lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"lint:eslint": "eslint . --fix",
		"lint": "run-s lint:*",
		"format": "prettier --write src/",
		"obs": "gfr obs ./dist/ -d fe-entry-task -g ff",
		"obs:audio": "gfr obs ./static/audio/ -d fe-entry-task/audio -g ff",
		"obs:images": "gfr obs ./static/images/ -d fe-entry-task/images -g ff",
		"transify": "gfr transify ./mock/lang/ -r 726,740 -i 1",
		"tpl": "gfr tpl ./dist/ -g ff -p fe-entry-task && run-p obs:images",
		"tpl:goku": "gfr tpl ./goku_dist/ -g ffgoku -p fe-entry-task"
	},
	"dependencies": {
		"@vueuse/core": "^13.9.0",
		"axios": "^1.12.2",
		"howler": "^2.2.4",
		"pinia": "^3.0.3",
		"vue": "^3.5.22",
		"vue-router": "^4.5.1"
	},
	"devDependencies": {
		"@playwright/test": "^1.55.1",
		"@prettier/plugin-oxc": "^0.0.4",
		"@tsconfig/node22": "^22.0.2",
		"@types/howler": "^2.2.12",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.18.6",
		"@types/postcss-pxtorem": "^6.1.0",
		"@vitejs/plugin-vue": "^6.0.1",
		"@vitejs/plugin-vue-jsx": "^5.1.1",
		"@vitest/eslint-plugin": "^1.3.13",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.6.0",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.8.1",
		"eslint": "^9.33.0",
		"eslint-plugin-oxlint": "~1.11.0",
		"eslint-plugin-playwright": "^2.2.2",
		"eslint-plugin-vue": "~10.4.0",
		"jiti": "^2.5.1",
		"jsdom": "^27.0.0",
		"mockjs": "^1.1.0",
		"npm-run-all2": "^8.0.4",
		"oxlint": "~1.11.0",
		"postcss-pxtorem": "^6.1.0",
		"prettier": "3.6.2",
		"sass": "^1.94.0",
		"typescript": "~5.9.0",
		"vite": "^7.1.7",
		"vite-plugin-mock": "^2.9.6",
		"vite-plugin-vue-devtools": "^8.0.2",
		"vitest": "^3.2.4",
		"vue-tsc": "^3.1.0"
	}
}